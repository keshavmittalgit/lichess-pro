{
  "name": "firefox-ext",
  "displayName": "Firefox ext",
  "version": "0.0.1",
  "description": "Firefox Mobile Extension",
  "author": "Plasmo Corp. <foss@plasmo.com>",
  "scripts": {
    "dev": "plasmo dev",
    "dev:firefox": "plasmo dev --target=firefox-mv3",
    "build": "plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv3",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "fairy-stockfish-nnue.wasm": "^1.1.11",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.18",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*"
    ],
    "permissions": [
      "scripting",
      "storage"
    ],
    "content_security_policy": {},
    "web_accessible_resources": [
      {
        "resources": [
          "inject-script.*.js"
        ],
        "matches": [
          "https://lichess.org/*"
        ]
      }
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "lichess-mob-ext@firefox.addon"
      }
    }
  }
}
